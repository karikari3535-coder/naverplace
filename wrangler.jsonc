{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2025-05-01",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // 로컬/임시용 관리자 토큰. 배포 환경에서는 시크릿으로 주입하는 것이 안전.
  "vars": {
    "ADMIN_TOKEN": "0b6FsFwa5Yy9Ha86MD0fBiFL1NMk82YDm4OJJsbH"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "naverplace-db",
      "database_id": "local"
    }
  ]
}
